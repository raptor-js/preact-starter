{
  "tasks": {
    "build": "deno run -A npm:vite build",
    "dev": "deno run -A npm:vite build --watch & deno run server:start",
    "server:start": "deno serve -A --watch ./bin/index.ts"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.6",
    "@raptor/error": "jsr:@raptor/error@^0.13.1",
    "@raptor/kernel": "jsr:@raptor/kernel@^0.20.0",
    "@raptor/router": "jsr:@raptor/router@^0.21.1",
    "@raptor/static": "jsr:@raptor/static@^0.8.1",
    "@raptor/validator": "jsr:@raptor/validator@^0.12.1",
    "autoprefixer": "npm:autoprefixer@^10.4.27",
    "cssnano": "npm:cssnano@^7.1.2",
    "esbuild": "npm:esbuild@^0.27.3",
    "esbuild-postcss": "npm:esbuild-postcss@^0.0.4",
    "postcss": "npm:postcss@^8.5.8",
    "preact": "npm:preact@10.28.4",
    "preact/jsx-runtime": "npm:preact@10.28.4/jsx-runtime",
    "preact/": "npm:preact@10.28.4/",
    "preact-iso": "npm:preact-iso@2.11.1",
    "ventojs": "npm:ventojs@^2.3.1",
    "vite": "npm:vite@^7.3.1",
    "@preact/preset-vite": "npm:@preact/preset-vite@^2.10.3"
  }
}